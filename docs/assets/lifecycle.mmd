---
config:
  look: handDrawn
  theme: base
  themeVariables:
    primaryColor: "#EDE9FE"
    primaryBorderColor: "#6B50FF"
    primaryTextColor: "#1F2937"
    lineColor: "#6B50FF"
    edgeLabelBackground: "#ffffff"
    fontSize: "15px"
---
flowchart TD
    A["<b>1 · Your goal, in plain English</b>"]
    B["<b>2 · The problem, broken down</b><br/>split into smaller steps, with the<br/>assumptions it depends on written out"]
    C["<b>3 · The AI agent starts executing</b><br/>one step at a time"]
    D{"<b>4 · Proof it actually works</b><br/>each step must show undeniable proof it is done —<br/>and that proof is run for real, not the agent's word.<br/>Did it pass?"}
    E["<b>5 · Step done, proof saved</b>"]
    F["<b>6 · Finished — a full, readable record</b>"]
    DASH(["<b>Anytime: a dashboard anyone can read</b><br/>status, decisions &amp; proof, in plain language"])
    MEM(["<b>Your decisions are remembered</b><br/>saved to a private memory that is yours.<br/>next time, the simple, safe decisions get<br/>made the way you would — without asking"])

    A --> B --> C --> D
    D -- "not yet: fix &amp; retry" --> C
    D -- "yes" --> E
    E -- "more steps" --> C
    E -- "last step" --> F
    C -.-> DASH
    C -. "your choices" .-> MEM

    classDef youstep fill:#DDD2FF,stroke:#6B50FF,stroke-width:3px,color:#1F2937;
    classDef look fill:#DCEBFF,stroke:#3B82C4,stroke-width:3px,color:#1F2937;
    classDef mem fill:#FFF1C9,stroke:#C99A2E,stroke-width:3px,color:#1F2937;
    class A,F youstep;
    class DASH look;
    class MEM mem;
